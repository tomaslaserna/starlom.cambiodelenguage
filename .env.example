# Supabase PostgreSQL — copiá estos valores de:
# Supabase Dashboard → Connect → Transaction pooler
# (el pooler es obligatorio en Vercel: el host directo db.*.supabase.co es solo IPv6)
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASS=

# Para Vercel: copiá estas variables en Project Settings → Environment Variables
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase Storage (subida de imágenes/comprobantes — REQUERIDO en Vercel,
# el disco serverless es efímero). Service role key: Dashboard → Settings → API.
# Además crear el bucket público "uploads" en Dashboard → Storage.
SUPABASE_SERVICE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Pepper de contraseñas (opcional; si no se setea usa el valor histórico.
# NO cambiarlo en un sistema con usuarios: rompe todos los hashes existentes)
STARLIM_PEPPER=

# API de integración (/integracion/*.php — para Make/n8n, bot WhatsApp).
# Generá una key larga y aleatoria; el cliente la manda en el header X-Api-Key.
STARLIM_API_KEY=

# Webhook saliente (opcional): si se setea, el ERP hace POST a esta URL en cada
# evento (venta creada, remito creado, cambio de estado de pedido/cobro).
# Alternativa sin webhook: polling a GET /integracion/eventos.php?desde_id=N
STARLIM_WEBHOOK_URL=

# Facturación ARCA/AFIP (por defecto: homologación con certificados de prueba)
AFIP_PRODUCTION=false
AFIP_CUIT=
AFIP_PTO_VTA=1
AFIP_SDK_TOKEN=
AFIP_CERT_PATH=
AFIP_KEY_PATH=
