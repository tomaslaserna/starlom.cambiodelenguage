SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASS=

# Optional alternative. If set, DATABASE_URL has priority over the individual
# SUPABASE_DB_* variables above.
DATABASE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only key for Supabase Storage uploads. Never expose this with NEXT_PUBLIC_*.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STARLIM_STORAGE_BUCKET=uploads

# Required for external JSON API access outside local development.
STARLIM_API_KEY=

# Used to sign the new Node/React session cookie. Generate a long random value
# before deploying outside local development.
STARLIM_SESSION_SECRET=

# Must match the PHP app pepper while legacy usuarios.contrasena hashes are used.
STARLIM_PEPPER=
